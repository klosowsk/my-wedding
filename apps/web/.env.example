# ===========================================
# Marriage Web — Environment Variables
# ===========================================

# --- Required ---

# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5435/marriage"

# Better Auth secret (generate: openssl rand -hex 32)
BETTER_AUTH_SECRET="change-me-to-a-random-string"

# Public URL of the site
NEXT_PUBLIC_APP_URL="http://localhost:3333"

# Superadmins (comma-separated emails). If empty, falls back to marriage.config.ts
# SUPERADMIN_EMAILS="you@example.com,partner@example.com"

# --- Storage: S3 / MinIO (local) / Cloudflare R2 (prod) ---

# S3-compatible endpoint
# Local: MinIO at localhost:9010
# Prod:  https://<account-id>.r2.cloudflarestorage.com
S3_ENDPOINT="http://localhost:9010"
S3_BUCKET="marriage-uploads"
S3_ACCESS_KEY="marriage"
S3_SECRET_KEY="marriage_dev_secret"
S3_REGION="us-east-1"
# true for MinIO (path-style: endpoint/bucket/key)
# false for R2/AWS (virtual-hosted: bucket.endpoint/key)
S3_FORCE_PATH_STYLE="true"
# Public URL for serving images to browsers.
# Local: MinIO endpoint/bucket (anonymous download enabled by minio-init)
# Prod:  Cloudflare R2 custom domain (e.g. https://media.wedding.yourdomain.com)
# S3_PUBLIC_URL="http://localhost:9010/marriage-uploads"

# --- Optional: Google Maps ---

# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""

# --- Optional: Invite Delivery (Twilio) ---

# TWILIO_ACCOUNT_SID=""
# TWILIO_AUTH_TOKEN=""
# TWILIO_FROM_PHONE=""
# TWILIO_WHATSAPP_FROM=""

# --- Optional: Invite Delivery (Email) ---

# RESEND_API_KEY=""

# --- Optional: Stripe Payments ---

# STRIPE_SECRET_KEY=""
# STRIPE_WEBHOOK_SECRET=""

# --- Optional: Deployment ---

# TUNNEL_TOKEN=""
